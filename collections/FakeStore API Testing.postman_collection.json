							"});",
							"",
							"pm.test(\"Product has price\", function () {",
							"    const response = pm.response.json();",
							"    pm.expect(response.price).to.be.a('number');",
							"});",
							"",
							"pm.test(\"Response time is below 2 sec\", function () {",
							"    pm.expect(pm.response.responseTime).to.be.below(2000);",
							"});",
							"",
							"pm.test(\"JSON Schema is valid\", function () {",
							"    const schema = {",
							"        type: \"object\",",
							"        required: [\"id\", \"title\", \"price\", \"category\", \"image\"],",
							"        properties: {",
							"            id: { type: \"number\" },",
							"            title: { type: \"string\" },",
							"            price: { type: \"number\" },",
							"            description: { type: \"string\" },",
							"            category: { type: \"string\" },",
							"            image: { type: \"string\" }",
							"        }",
							"    };",
							"",
							"    const response = pm.response.json();",
							"    pm.expect(tv4.validate(response, schema)).to.be.true;",
							"});"
